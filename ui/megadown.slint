import { LineEdit, ScrollView, TextEdit } from "std-widgets.slint";

export struct UiTask {
    id: string,
    file_name: string,
    detail: string,
    status_text: string,
    status_kind: string,
    downloaded_text: string,
    speed_text: string,
    eta_text: string,
    config_text: string,
    output_dir: string,
    output_path: string,
    current_file: string,
    error_text: string,
    url: string,
    created_at: string,
    updated_at: string,
    progress_value: float,
    can_pause: bool,
    can_resume: bool,
    can_cancel: bool,
    can_open: bool,
    can_retry: bool,
    can_delete: bool,
}

component Card inherits Rectangle {
    border-radius: 8px;
    border-width: 1px;
    border-color: #dfe5ee;
    background: #ffffff;
}

component SectionTitle inherits Text {
    in property <string> label;
    text: label;
    color: #202838;
    font-size: 16px;
    font-weight: 800;
}

component FieldLabel inherits Text {
    in property <string> label;
    text: label;
    color: #657184;
    font-size: 12px;
    font-weight: 700;
    vertical-alignment: center;
}

component BrandMark inherits Rectangle {
    width: 46px;
    height: 46px;
    border-radius: 8px;
    background: #d8293a;

    Text {
        width: parent.width;
        height: parent.height;
        text: "M";
        color: #ffffff;
        font-size: 22px;
        font-weight: 900;
        horizontal-alignment: center;
        vertical-alignment: center;
    }
}

component ModernButton inherits Rectangle {
    in property <string> label;
    in property <bool> primary;
    in property <bool> danger;
    in property <bool> enabled: true;
    in property <length> button_width: 96px;
    callback clicked();

    height: 38px;
    width: button_width;
    border-radius: 7px;
    border-width: primary ? 0px : 1px;
    border-color: danger ? #e7a9b0 : #cbd3dd;
    background: !enabled ? #eef1f5 :
        primary ? (button_area.pressed ? #b91f2d : button_area.has-hover ? #c92536 : #d8293a) :
        danger ? (button_area.pressed ? #ffe2e7 : button_area.has-hover ? #fff5f6 : #fff0f2) :
        button_area.pressed ? #e8edf3 : button_area.has-hover ? #f7f9fc : #ffffff;

    Text {
        width: parent.width;
        height: parent.height;
        text: root.label;
        color: !root.enabled ? #9aa3af :
            root.primary ? #ffffff :
            root.danger ? #d8293a :
            #263140;
        font-size: 13px;
        font-weight: 820;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    button_area := TouchArea {
        enabled: root.enabled;
        clicked => { root.clicked(); }
    }
}

component ActionButton inherits ModernButton {
    height: 30px;
    button_width: 60px;
}

component ChoiceButton inherits Rectangle {
    in property <string> label;
    in property <bool> active;
    in property <int> index;
    in property <length> button_width: 76px;
    callback selected(int);

    height: 38px;
    width: button_width;
    border-radius: 7px;
    border-width: 1px;
    border-color: active ? #f0b8c0 : #d9dfe7;
    background: active ? #fff0f2 :
        choice_area.pressed ? #e8edf3 :
        choice_area.has-hover ? #f7f9fc :
        #ffffff;

    Text {
        width: parent.width;
        height: parent.height;
        text: root.label;
        color: root.active ? #d8293a : #334052;
        font-size: 13px;
        font-weight: 800;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    choice_area := TouchArea {
        clicked => { root.selected(root.index); }
    }
}

component ToggleChoice inherits Rectangle {
    in property <string> label;
    in property <bool> checked;
    callback toggled(bool);

    height: 38px;
    min-width: 150px;
    border-radius: 7px;
    border-width: 1px;
    border-color: checked ? #f0b8c0 : #d9dfe7;
    background: checked ? #fff0f2 :
        toggle_area.pressed ? #e8edf3 :
        toggle_area.has-hover ? #f7f9fc :
        #ffffff;

    HorizontalLayout {
        alignment: center;
        padding-left: 12px;
        padding-right: 12px;
        spacing: 8px;

        Rectangle {
            width: 16px;
            height: 16px;
            border-radius: 4px;
            border-width: 1px;
            border-color: root.checked ? #d8293a : #aeb8c5;
            background: root.checked ? #d8293a : #ffffff;

            if root.checked : Text {
                width: parent.width;
                height: parent.height;
                text: "✓";
                color: #ffffff;
                font-size: 12px;
                font-weight: 900;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }

        Text {
            height: parent.height;
            text: root.label;
            color: root.checked ? #d8293a : #334052;
            font-size: 13px;
            font-weight: 760;
            vertical-alignment: center;
        }
    }

    toggle_area := TouchArea {
        clicked => { root.toggled(!root.checked); }
    }
}

component TabButton inherits Rectangle {
    in property <string> label;
    in property <string> count;
    in property <bool> active;
    in property <int> index;
    callback tab_clicked(int);

    min-width: 94px;
    height: 34px;
    border-radius: 6px;
    background: active ? #ffffff : transparent;

    HorizontalLayout {
        padding-left: 12px;
        padding-right: 12px;
        spacing: 7px;

        Text {
            text: root.label;
            color: root.active ? #d8293a : #4d5663;
            font-size: 13px;
            font-weight: 800;
            vertical-alignment: center;
        }

        if root.count != "" : Rectangle {
            min-width: 18px;
            height: 18px;
            border-radius: 9px;
            background: root.active ? #fff0f2 : #dde4ed;

            Text {
                width: parent.width;
                height: parent.height;
                text: root.count;
                color: root.active ? #d8293a : #44505f;
                font-size: 11px;
                font-weight: 800;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }
    }

    TouchArea {
        clicked => { root.tab_clicked(root.index); }
    }
}

component StatTile inherits Card {
    in property <string> value;
    in property <string> label;
    min-width: 108px;
    height: 50px;

    HorizontalLayout {
        padding-left: 11px;
        padding-right: 11px;

        VerticalLayout {
            spacing: 2px;

            Text {
                text: root.value;
                color: #171d28;
                font-size: 18px;
                font-weight: 850;
            }

            Text {
                text: root.label;
                color: #6b7686;
                font-size: 12px;
            }
        }
    }
}

component StatusDot inherits Rectangle {
    in property <string> status_kind;
    width: 10px;
    height: 10px;
    border-radius: 5px;
    background: status_kind == "completed" ? #17865d :
        status_kind == "failed" ? #d8293a :
        status_kind == "cancelled" ? #7d8794 :
        status_kind == "paused" ? #a66a00 :
        #226fbd;
}

component ProgressLine inherits Rectangle {
    in property <float> value;
    in property <string> status_kind;
    height: 7px;
    border-radius: 4px;
    background: #e8edf3;

    Rectangle {
        height: parent.height;
        width: parent.width * root.value / 100;
        border-radius: 4px;
        background: root.status_kind == "completed" ? #17865d :
            root.status_kind == "failed" ? #d8293a :
            root.status_kind == "cancelled" ? #7d8794 :
            root.status_kind == "paused" ? #a66a00 :
            #226fbd;
    }
}

component FilterButton inherits Rectangle {
    in property <string> label;
    in property <string> count;
    in property <bool> active;
    in property <int> index;
    callback filter_clicked(int);

    height: 36px;
    border-radius: 7px;
    border-width: 1px;
    border-color: active ? #f0b8c0 : transparent;
    background: active ? #fff0f2 : transparent;

    HorizontalLayout {
        padding-left: 10px;
        padding-right: 10px;
        spacing: 8px;

        Text {
            text: root.label;
            color: root.active ? #d8293a : #4b5565;
            font-size: 13px;
            font-weight: 760;
            vertical-alignment: center;
        }

        Rectangle { horizontal-stretch: 1; }

        Text {
            text: root.count;
            color: root.active ? #d8293a : #748093;
            font-size: 12px;
            font-weight: 800;
            vertical-alignment: center;
        }
    }

    TouchArea {
        clicked => { root.filter_clicked(root.index); }
    }
}

component DetailRow inherits Rectangle {
    in property <string> label;
    in property <string> value;
    height: 31px;

    HorizontalLayout {
        spacing: 10px;

        Text {
            text: root.label;
            width: 72px;
            color: #5b6574;
            font-size: 12px;
            font-weight: 760;
            vertical-alignment: center;
        }

        Text {
            text: root.value;
            color: #202838;
            font-size: 12px;
            overflow: elide;
            vertical-alignment: center;
        }
    }
}

component EmptyState inherits Rectangle {
    in property <string> title;
    in property <string> text;

    VerticalLayout {
        alignment: center;
        spacing: 8px;

        Text {
            text: root.title;
            color: #202838;
            font-size: 18px;
            font-weight: 850;
            horizontal-alignment: center;
        }

        Text {
            text: root.text;
            color: #6b7686;
            font-size: 13px;
            horizontal-alignment: center;
        }
    }
}

component TaskRow inherits Card {
    in property <UiTask> task;
    in property <bool> selected;
    callback row_selected(string);
    callback pause(string);
    callback resume(string);
    callback cancel(string);
    callback open_file(string);
    callback open_folder(string);
    callback retry(string);
    callback delete_task(string);

    height: 104px;
    border-color: selected ? #d8293a : #dfe5ee;
    background: selected ? #fffafa : #ffffff;

    VerticalLayout {
        padding-left: 12px;
        padding-right: 12px;
        padding-top: 10px;
        padding-bottom: 10px;
        spacing: 8px;

        HorizontalLayout {
            spacing: 10px;

            StatusDot {
                status_kind: root.task.status_kind;
                vertical-stretch: 0;
            }

            VerticalLayout {
                spacing: 3px;
                horizontal-stretch: 1;

                Text {
                    text: root.task.file_name;
                    color: #171d28;
                    font-size: 14px;
                    font-weight: 850;
                    overflow: elide;
                }

                Text {
                    text: root.task.detail;
                    color: #6b7686;
                    font-size: 12px;
                    overflow: elide;
                }
            }

            Text {
                text: root.task.status_text;
                color: root.task.status_kind == "failed" ? #d8293a :
                    root.task.status_kind == "completed" ? #17865d :
                    root.task.status_kind == "paused" ? #a66a00 : #226fbd;
                font-size: 12px;
                font-weight: 850;
                vertical-alignment: center;
            }
        }

        ProgressLine {
            value: root.task.progress_value;
            status_kind: root.task.status_kind;
        }

        HorizontalLayout {
            spacing: 6px;
            height: 32px;

            Text {
                text: root.task.downloaded_text + "  " + root.task.speed_text + "  " + root.task.eta_text;
                color: #657184;
                font-size: 12px;
                overflow: elide;
                vertical-alignment: center;
                horizontal-stretch: 1;
            }

            ActionButton {
                label: "详情";
                clicked => { root.row_selected(root.task.id); }
            }

            if root.task.can_pause : ActionButton {
                label: "暂停";
                clicked => { root.pause(root.task.id); }
            }

            if root.task.can_resume : ActionButton {
                label: "继续";
                clicked => { root.resume(root.task.id); }
            }

            if root.task.can_cancel : ActionButton {
                label: "取消";
                danger: true;
                clicked => { root.cancel(root.task.id); }
            }

            if root.task.can_open : ActionButton {
                label: "打开";
                clicked => { root.open_file(root.task.id); }
            }

            if root.task.can_open : ActionButton {
                label: "目录";
                clicked => { root.open_folder(root.task.id); }
            }

            if root.task.can_retry : ActionButton {
                label: root.task.status_kind == "completed" ? "重下" : "重试";
                clicked => { root.retry(root.task.id); }
            }

            if root.task.can_delete : ActionButton {
                label: "删除";
                danger: true;
                clicked => { root.delete_task(root.task.id); }
            }
        }
    }
}

component FilterPanel inherits Card {
    in property <int> filter_index;
    in property <string> all_count;
    in property <string> active_count;
    in property <string> paused_count;
    in property <string> completed_count;
    in property <string> failed_count;
    in property <string> cancelled_count;
    callback filter_requested(int);

    width: 180px;

    VerticalLayout {
        padding: 10px;
        spacing: 5px;

        Text {
            text: "任务视图";
            color: #657184;
            font-size: 12px;
            font-weight: 800;
        }

        FilterButton { label: "全部"; count: root.all_count; index: 0; active: root.filter_index == 0; filter_clicked(index) => { root.filter_requested(index); } }
        FilterButton { label: "下载中"; count: root.active_count; index: 1; active: root.filter_index == 1; filter_clicked(index) => { root.filter_requested(index); } }
        FilterButton { label: "已暂停"; count: root.paused_count; index: 2; active: root.filter_index == 2; filter_clicked(index) => { root.filter_requested(index); } }
        FilterButton { label: "已完成"; count: root.completed_count; index: 3; active: root.filter_index == 3; filter_clicked(index) => { root.filter_requested(index); } }
        FilterButton { label: "失败"; count: root.failed_count; index: 4; active: root.filter_index == 4; filter_clicked(index) => { root.filter_requested(index); } }
        FilterButton { label: "已取消"; count: root.cancelled_count; index: 5; active: root.filter_index == 5; filter_clicked(index) => { root.filter_requested(index); } }

        Rectangle { vertical-stretch: 1; }
    }
}

export component MegaDownWindow inherits Window {
    title: "MegaDown";
    icon: @image-url("../assets/icons/icon.ico");
    preferred-width: 1180px;
    preferred-height: 760px;
    min-width: 980px;
    min-height: 660px;
    background: #f6f7f9;

    in-out property <string> url_text;
    in-out property <string> password_text;
    in-out property <string> output_dir;
    in-out property <int> performance_mode_index: 0;
    in-out property <int> connections_index: 2;
    in-out property <int> chunk_size_index: 2;
    in-out property <int> retry_mode_index: 0;
    in-out property <bool> overwrite_enabled;
    in-out property <bool> verify_enabled;
    in-out property <int> filter_index: 0;
    in-out property <int> active_tab: 0;
    in property <[UiTask]> tasks;
    in property <UiTask> selected_task;
    in property <bool> has_selected_task;
    in property <string> notice_title;
    in property <string> notice_text;
    in property <bool> notice_is_error;
    in property <bool> busy;
    in property <string> all_count;
    in property <string> active_count;
    in property <string> paused_count;
    in property <string> completed_count;
    in property <string> failed_count;
    in property <string> cancelled_count;
    in property <string> visible_count_text;
    in property <string> total_speed_text;
    in property <bool> has_pausable;
    in property <bool> has_paused;
    in property <bool> has_clearable;

    callback inspect_requested();
    callback start_requested();
    callback choose_dir_requested();
    callback filter_requested(int);
    callback select_task(string);
    callback pause_task(string);
    callback resume_task(string);
    callback cancel_task(string);
    callback open_task_file(string);
    callback open_task_folder(string);
    callback retry_task(string);
    callback delete_task(string);
    callback pause_all_requested();
    callback resume_all_requested();
    callback clear_finished_requested();

    VerticalLayout {
        padding: 12px;
        spacing: 10px;

        HorizontalLayout {
            height: 56px;
            spacing: 14px;

            BrandMark {}

            VerticalLayout {
                width: 250px;
                spacing: 2px;

                Text {
                    text: "MegaDown";
                    color: #111722;
                    font-size: 22px;
                    font-weight: 900;
                }

                Text {
                    text: "MEGA 下载管理器";
                    color: #667180;
                    font-size: 13px;
                }
            }

            Rectangle { horizontal-stretch: 1; }

            Rectangle {
                height: 40px;
                min-width: 318px;
                border-radius: 8px;
                border-width: 1px;
                border-color: #dfe5ee;
                background: #eef2f6;

                HorizontalLayout {
                    padding: 3px;
                    spacing: 3px;

                    TabButton { label: "下载"; count: ""; index: 0; active: root.active_tab == 0; tab_clicked(index) => { root.active_tab = index; } }
                    TabButton { label: "任务"; count: root.all_count; index: 1; active: root.active_tab == 1; tab_clicked(index) => { root.active_tab = index; } }
                    TabButton { label: "设置"; count: ""; index: 2; active: root.active_tab == 2; tab_clicked(index) => { root.active_tab = index; } }
                }
            }
        }

        if root.notice_title != "" : Card {
            height: 46px;
            background: root.notice_is_error ? #fff0f2 : #ffffff;
            border-color: root.notice_is_error ? #e7a9b0 : #dfe5ee;

            HorizontalLayout {
                padding-left: 13px;
                padding-right: 13px;
                spacing: 14px;

                Text {
                    text: root.notice_title;
                    color: root.notice_is_error ? #d8293a : #202838;
                    font-size: 14px;
                    font-weight: 850;
                    vertical-alignment: center;
                }

                Text {
                    text: root.notice_text;
                    color: #657184;
                    font-size: 13px;
                    overflow: elide;
                    vertical-alignment: center;
                    horizontal-stretch: 1;
                }
            }
        }

        if root.active_tab == 0 : Rectangle {
            vertical-stretch: 1;

            download_card := Card {
                width: 860px;
                height: 356px;
                x: (parent.width - self.width) / 2;
                y: 18px;

                VerticalLayout {
                    padding: 20px;
                    spacing: 14px;

                    SectionTitle { label: "新建下载"; }

                    TextEdit {
                        text <=> root.url_text;
                        height: 148px;
                        placeholder-text: "粘贴一个或多个 MEGA 公共链接，每行一个";
                        horizontal-stretch: 1;
                    }

                    HorizontalLayout {
                        spacing: 12px;
                        alignment: center;

                        VerticalLayout {
                            spacing: 7px;
                            horizontal-stretch: 1;

                            FieldLabel { label: "保存目录"; }

                            HorizontalLayout {
                                spacing: 8px;
                                alignment: center;

                                LineEdit {
                                    text <=> root.output_dir;
                                    placeholder-text: "默认下载目录";
                                    horizontal-stretch: 1;
                                }

                                ModernButton {
                                    label: "选择";
                                    button_width: 78px;
                                    clicked => { root.choose_dir_requested(); }
                                }
                            }
                        }

                        VerticalLayout {
                            spacing: 7px;
                            width: 260px;

                            FieldLabel { label: "共享密码"; }

                            LineEdit {
                                text <=> root.password_text;
                                input-type: password;
                                placeholder-text: "密码保护链接可填写";
                            }
                        }
                    }

                    HorizontalLayout {
                        spacing: 10px;
                        alignment: center;

                        Rectangle { horizontal-stretch: 1; }

                        ModernButton {
                            label: root.busy ? "处理中" : "预览链接";
                            button_width: 138px;
                            height: 42px;
                            enabled: !root.busy;
                            clicked => { root.inspect_requested(); }
                        }

                        ModernButton {
                            label: root.busy ? "处理中" : "开始下载";
                            button_width: 150px;
                            height: 42px;
                            primary: true;
                            enabled: !root.busy;
                            clicked => { root.start_requested(); }
                        }
                    }
                }
            }

            if root.all_count != "0" : recent_card := Card {
                width: 860px;
                height: 218px;
                x: download_card.x;
                y: download_card.y + download_card.height + 12px;

                VerticalLayout {
                    padding: 14px;
                    spacing: 10px;

                    HorizontalLayout {
                        SectionTitle { label: "最近任务"; }
                        Rectangle { horizontal-stretch: 1; }
                        ModernButton {
                            label: "打开队列";
                            button_width: 102px;
                            height: 34px;
                            clicked => { root.active_tab = 1; }
                        }
                    }

                    ScrollView {
                        height: 148px;

                        VerticalLayout {
                            spacing: 8px;

                            for task in root.tasks : TaskRow {
                                task: task;
                                selected: task.id == root.selected_task.id;
                                row_selected(id) => { root.select_task(id); }
                                pause(id) => { root.pause_task(id); }
                                resume(id) => { root.resume_task(id); }
                                cancel(id) => { root.cancel_task(id); }
                                open_file(id) => { root.open_task_file(id); }
                                open_folder(id) => { root.open_task_folder(id); }
                                retry(id) => { root.retry_task(id); }
                                delete_task(id) => { root.delete_task(id); }
                            }
                        }
                    }
                }
            }
        }

        if root.active_tab == 1 : VerticalLayout {
            spacing: 12px;
            vertical-stretch: 1;

            Card {
                height: 70px;

                HorizontalLayout {
                    padding: 10px;
                    spacing: 8px;

                    ModernButton {
                        label: "全部暂停";
                        button_width: 110px;
                        enabled: root.has_pausable;
                        clicked => { root.pause_all_requested(); }
                    }

                    ModernButton {
                        label: "全部继续";
                        button_width: 110px;
                        enabled: root.has_paused;
                        clicked => { root.resume_all_requested(); }
                    }

                    ModernButton {
                        label: "清空已结束";
                        button_width: 122px;
                        danger: true;
                        enabled: root.has_clearable;
                        clicked => { root.clear_finished_requested(); }
                    }

                    Rectangle { horizontal-stretch: 1; }

                    StatTile { value: root.all_count; label: "全部任务"; }
                    StatTile { value: root.active_count; label: "进行中"; }
                    StatTile { value: root.completed_count; label: "已完成"; }
                    StatTile { value: root.total_speed_text; label: "总速度"; min-width: 132px; }
                }
            }

            HorizontalLayout {
                spacing: 12px;
                vertical-stretch: 1;

                FilterPanel {
                    filter_index: root.filter_index;
                    all_count: root.all_count;
                    active_count: root.active_count;
                    paused_count: root.paused_count;
                    completed_count: root.completed_count;
                    failed_count: root.failed_count;
                    cancelled_count: root.cancelled_count;
                    filter_requested(index) => { root.filter_requested(index); }
                }

                Card {
                    horizontal-stretch: 1;

                    VerticalLayout {
                        padding: 14px;
                        spacing: 10px;

                        HorizontalLayout {
                            SectionTitle { label: "下载队列"; }
                            Rectangle { horizontal-stretch: 1; }
                            Text {
                                text: root.visible_count_text;
                                color: #657184;
                                font-size: 12px;
                                vertical-alignment: center;
                            }
                        }

                        ScrollView {
                            vertical-stretch: 1;

                            VerticalLayout {
                                spacing: 8px;

                                for task in root.tasks : TaskRow {
                                    task: task;
                                    selected: task.id == root.selected_task.id;
                                    row_selected(id) => { root.select_task(id); }
                                    pause(id) => { root.pause_task(id); }
                                    resume(id) => { root.resume_task(id); }
                                    cancel(id) => { root.cancel_task(id); }
                                    open_file(id) => { root.open_task_file(id); }
                                    open_folder(id) => { root.open_task_folder(id); }
                                    retry(id) => { root.retry_task(id); }
                                    delete_task(id) => { root.delete_task(id); }
                                }

                                if root.tasks.length == 0 : EmptyState {
                                    min-height: 300px;
                                    title: root.all_count == "0" ? "暂无任务" : "当前视图没有任务";
                                    text: root.all_count == "0" ? "添加公共文件或文件夹链接后会显示进度。" : "切换左侧筛选可查看其他状态。";
                                }
                            }
                        }
                    }
                }

                Card {
                    width: 340px;

                    VerticalLayout {
                        padding: 14px;
                        spacing: 10px;

                        SectionTitle { label: "任务详情"; }

                        if !root.has_selected_task : EmptyState {
                            vertical-stretch: 1;
                            title: "未选择任务";
                            text: "选择队列中的任务可查看链接、路径和下载参数。";
                        }

                        if root.has_selected_task : ScrollView {
                            vertical-stretch: 1;

                            VerticalLayout {
                                spacing: 10px;

                                Text {
                                    text: root.selected_task.file_name;
                                    color: #171d28;
                                    font-size: 16px;
                                    font-weight: 900;
                                    overflow: elide;
                                }

                                ProgressLine {
                                    value: root.selected_task.progress_value;
                                    status_kind: root.selected_task.status_kind;
                                }

                                DetailRow { label: "状态"; value: root.selected_task.status_text + " · " + root.selected_task.eta_text; }
                                DetailRow { label: "大小"; value: root.selected_task.downloaded_text; }
                                DetailRow { label: "速度"; value: root.selected_task.speed_text; }
                                DetailRow { label: "参数"; value: root.selected_task.config_text; }
                                DetailRow { label: "保存目录"; value: root.selected_task.output_dir; }
                                DetailRow { label: "保存路径"; value: root.selected_task.output_path; }
                                DetailRow { label: "当前文件"; value: root.selected_task.current_file; }
                                DetailRow { label: "创建时间"; value: root.selected_task.created_at; }
                                DetailRow { label: "更新时间"; value: root.selected_task.updated_at; }
                                DetailRow { label: "错误"; value: root.selected_task.error_text; }
                                DetailRow { label: "链接"; value: root.selected_task.url; }
                            }
                        }
                    }
                }
            }
        }

        if root.active_tab == 2 : Rectangle {
            vertical-stretch: 1;

            settings_card := Card {
                width: 820px;
                height: 468px;
                x: (parent.width - self.width) / 2;
                y: 18px;

                VerticalLayout {
                    padding: 22px;
                    spacing: 16px;

                    SectionTitle { label: "传输设置"; }

                    HorizontalLayout {
                        height: 48px;
                        spacing: 16px;
                        alignment: center;

                        FieldLabel { label: "性能模式"; width: 110px; }

                        HorizontalLayout {
                            spacing: 8px;

                            ChoiceButton { label: "均衡"; index: 0; active: root.performance_mode_index == 0; selected(index) => { root.performance_mode_index = index; } }
                            ChoiceButton { label: "极速"; index: 1; active: root.performance_mode_index == 1; selected(index) => { root.performance_mode_index = index; } }
                            ChoiceButton { label: "低占用"; index: 2; active: root.performance_mode_index == 2; selected(index) => { root.performance_mode_index = index; } }
                        }

                        Rectangle { horizontal-stretch: 1; }
                    }

                    Rectangle {
                        height: 1px;
                        background: #edf1f5;
                    }

                    HorizontalLayout {
                        height: 48px;
                        spacing: 16px;
                        alignment: center;

                        FieldLabel { label: "连接数"; width: 110px; }

                        HorizontalLayout {
                            spacing: 8px;

                            ChoiceButton { label: "2"; index: 0; active: root.connections_index == 0; selected(index) => { root.connections_index = index; } }
                            ChoiceButton { label: "4"; index: 1; active: root.connections_index == 1; selected(index) => { root.connections_index = index; } }
                            ChoiceButton { label: "8"; index: 2; active: root.connections_index == 2; selected(index) => { root.connections_index = index; } }
                            ChoiceButton { label: "12"; index: 3; active: root.connections_index == 3; selected(index) => { root.connections_index = index; } }
                            ChoiceButton { label: "16"; index: 4; active: root.connections_index == 4; selected(index) => { root.connections_index = index; } }
                            ChoiceButton { label: "24"; index: 5; active: root.connections_index == 5; selected(index) => { root.connections_index = index; } }
                            ChoiceButton { label: "32"; index: 6; active: root.connections_index == 6; selected(index) => { root.connections_index = index; } }
                        }

                        Rectangle { horizontal-stretch: 1; }
                    }

                    Rectangle {
                        height: 1px;
                        background: #edf1f5;
                    }

                    HorizontalLayout {
                        height: 48px;
                        spacing: 16px;
                        alignment: center;

                        FieldLabel { label: "分片大小"; width: 110px; }

                        HorizontalLayout {
                            spacing: 8px;

                            ChoiceButton { label: "2 MB"; index: 0; active: root.chunk_size_index == 0; selected(index) => { root.chunk_size_index = index; } }
                            ChoiceButton { label: "4 MB"; index: 1; active: root.chunk_size_index == 1; selected(index) => { root.chunk_size_index = index; } }
                            ChoiceButton { label: "8 MB"; index: 2; active: root.chunk_size_index == 2; selected(index) => { root.chunk_size_index = index; } }
                            ChoiceButton { label: "16 MB"; index: 3; active: root.chunk_size_index == 3; selected(index) => { root.chunk_size_index = index; } }
                            ChoiceButton { label: "32 MB"; index: 4; active: root.chunk_size_index == 4; selected(index) => { root.chunk_size_index = index; } }
                        }

                        Rectangle { horizontal-stretch: 1; }
                    }

                    Rectangle {
                        height: 1px;
                        background: #edf1f5;
                    }

                    HorizontalLayout {
                        height: 48px;
                        spacing: 16px;
                        alignment: center;

                        FieldLabel { label: "失败处理"; width: 110px; }

                        HorizontalLayout {
                            spacing: 8px;

                            ChoiceButton { label: "自动重试"; button_width: 112px; index: 0; active: root.retry_mode_index == 0; selected(index) => { root.retry_mode_index = index; } }
                            ChoiceButton { label: "手动重试"; button_width: 112px; index: 1; active: root.retry_mode_index == 1; selected(index) => { root.retry_mode_index = index; } }
                        }

                        Rectangle { horizontal-stretch: 1; }
                    }

                    Rectangle {
                        height: 1px;
                        background: #edf1f5;
                    }

                    HorizontalLayout {
                        height: 48px;
                        spacing: 16px;
                        alignment: center;

                        FieldLabel { label: "文件处理"; width: 110px; }

                        HorizontalLayout {
                            spacing: 10px;

                            ToggleChoice { label: "覆盖已有文件"; checked: root.overwrite_enabled; toggled(value) => { root.overwrite_enabled = value; } }
                            ToggleChoice { label: "完整校验"; checked: root.verify_enabled; toggled(value) => { root.verify_enabled = value; } }
                        }

                        Rectangle { horizontal-stretch: 1; }
                    }
                }
            }
        }
    }
}
